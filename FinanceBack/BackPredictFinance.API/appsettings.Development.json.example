{
  // Copier ce fichier en `appsettings.Development.json` (gitignore) et renseigner les valeurs.
  // Aucune valeur reelle ne doit etre commitee.
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.\\sqlexpress;Database=FinanceBdd;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:4200"
  },

  // Poivre serveur utilise pour hacher les refresh tokens (JwtGeneratorService.HashRefresh).
  // Generer : openssl rand -base64 32
  "ServerSalt": "__SET_ME_BASE64_32_BYTES__",

  // Comptes seedes au demarrage par DatabaseUpdater.
  "adminEmail": "admin@finance.fr",
  "adminPwd": "__SET_ME_STRONG_PASSWORD__",
  "userEmail": "user@finance.fr",
  "userPwd": "__SET_ME_STRONG_PASSWORD__",

  "JWTToken": {
    // Cle de signature. Generer : openssl rand -base64 64
    "Secret": "__SET_ME_LONG_RANDOM_SECRET__",
    "Issuer": "localhost",
    "Audience": "localhost"
  },

  // Optionnel en dev : laisser vide desactive l'envoi de mail.
  "EmailService": {
    "SmtpServer": "__SET_ME__",
    "Port": 587,
    "UserName": "__SET_ME__",
    "Password": "__SET_ME__"
  }
}
