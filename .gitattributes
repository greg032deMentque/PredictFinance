# Normalisation des fins de ligne : LF dans le repo, natif dans le working dir.
* text=auto eol=lf

# Fichiers Windows-only : CRLF obligatoire
*.sln       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binaires : pas de normalisation
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.dll       binary
*.exe       binary
*.snk       binary
