{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=__SET_ME__;Database=PredictFinance;User Id=__SET_ME__;Password=__SET_ME__;TrustServerCertificate=True"
  },

  "Frontend": {
    "BaseUrl": "https://app.predictfinance.local"
  },

  "ServerSalt": "__SET_ME_BASE64__",

  "JWTToken": {
    "Secret": "__SET_ME_WITH_A_LONG_RANDOM_SECRET__",
    "ValidityMinutesRefreshToken": 43200,
    "ValidityMinutesAcessToken": 60,
    "Issuer": "predictfinance-api",
    "Audience": "predictfinance-front"
  },


  "PythonCli": {
    "PythonExe": "python",
    "WorkingDirectory": ".",
    "ModelDir": "artifacts/double_top",
    "ModelVersion": "double_top@v1",
    "DefaultPattern": "DOUBLE_TOP",
    "Patterns": {
      "DOUBLE_TOP": {
        "Enabled": true,
        "ModelDir": "artifacts/double_top",
        "ModelVersion": "double_top@v1"
      }
    },
    "Period": "6mo",
    "TimeoutSeconds": 30,
    "SellThreshold": 0.65,
    "BuyThreshold": 0.20,
    "MinPrecision": 0.55,
    "MinF1": 0.45,
    "MinRocAuc": 0.60,
    "MinPositives": 20
  },

  "EmailService": {
    "From": "no-reply@predictfinance.local",
    "FromName": "PredictFinance",
    "SmtpServer": "__SET_ME__",
    "Port": 587,
    "UserName": "__SET_ME__",
    "Password": "__SET_ME__"
  }
}
